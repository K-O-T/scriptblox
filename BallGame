-- Функция отправки вебхука в Discord
local function sendWebhook(url, content)
   local success, err = pcall(function()
      local request = syn and syn.request or http_request or chunk and chunk.request or writefile and request
      if request then
         request({
            Url = url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ content = content })
         })
      else
         warn("HTTP Request Error.")
      end
   end)
   if not success then warn("Webhook Error: " .. tostring(err)) end
end

