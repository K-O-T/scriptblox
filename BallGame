-- Функция сбора и отправки аналитики
local function sendAnalytics()
   if not analyticsEnabled then return end
   
   -- Проверяем количество перерождений перед отправкой
   local success3, Rebirths = pcall(function() return gethiddenproperty(LocalPlayer.leaderstats.Rebirths, "Value") end)
   
   -- Если чтение успешно и значение числовое, проверяем условие
   if success3 and tonumber(Rebirths) and tonumber(Rebirths) > 22 then
      local success1, CurrentLuck = pcall(function() return gethiddenproperty(LocalPlayer.PlayerGui.BallGameUI:GetChildren()[12].TextLabel, "Text") end)
      local success2, Money = pcall(function() return gethiddenproperty(LocalPlayer.leaderstats.Money, "Value") end)
      local success4, BestRoll = pcall(function() return gethiddenproperty(LocalPlayer.leaderstats["Best Roll"], "Value") end)
      
      CurrentLuck = success1 and CurrentLuck or "Error"
      Money = success2 and Money or "Error"
      Rebirths = success3 and Rebirths or "Error"
      BestRoll = success4 and BestRoll or "Error"

      -- Форматирование текста
      local message = string.format("@%s \n• Current Luck: %s\n• Money: %s\n• Rebirths: %s\n• Best Roll: %s.", 
         LocalPlayer.Name, 
         tostring(CurrentLuck), 
         tostring(Money), 
         tostring(Rebirths), 
         tostring(BestRoll)
      )
      
      sendWebhook(WEBHOOK_ANALYTICS_URL, message)
   end
end

