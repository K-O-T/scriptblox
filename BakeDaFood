local customRarity = "Common"
local applyRarity = false
local customFoodName = "Egg"
local applyName = false

-- Таблица редкостей по умолчанию
local rarityGroups = {
    Common = {"Egg", "Bread", "Carrot", "Corn", "FishStick"},
    Uncommon = {"Sausage", "Croissant", "ChocolateCroissant", "WaffleBatter", "MeatSkewer", "ChickenThigh"},
    Rare = {"Tomato", "BellPepper", "Apple", "Bacon", "PorkMeat", "Beef", "Burger Bun"},
    Epic = {"BagOfCocoaBeans", "Banana", "Potato", "CookieDought", "Cheese", "Mushroom", "DonutBase", "HotDogKit", "SquareSandwich", "TriangularSandwich"},
    Legendary = {"BagOfEggs", "PizzaDough", "Chicken", "Spaghetti", "Tacos", "Burritos", "PancakeBatter", "Lasagna", "BagOfApples", "BagOfLemon", "BagOfStrawberries", "BigBurgerBun"},
    Mythic = {"Salmon", "Pumpkin", "Crab", "Shrimp", "Sweetbreads", "CakeBase", "BigBeef"},
    Secret = {"Snake", "GiantCrab", "Lobster", "Octopus", "Shark"}
}

-- Функция для получения редкости
local function getRarity()
    if applyRarity then return customRarity end
    for rarity, list in pairs(rarityGroups) do
        if table.find(list, selectedFoodType) then return rarity end
    end
    return "Common"
end

-- Функция для форматирования имени (разделение заглавных букв пробелами)
local function formatName(str)
    if applyName then return customFoodName end
    return str:gsub("(%l)(%th)", "%1 %2")
end

