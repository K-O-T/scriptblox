-- Создаем список имен зон из папки Workspace.Map.Zones
local zonesFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Zones")
local zoneNames = {}

if zonesFolder then
    for _, zone in pairs(zonesFolder:GetChildren()) do
        table.insert(zoneNames, zone.Name)
    end
else
    table.insert(zoneNames, "Zones not found") -- Заглушка, если папка пуста
end

-- Dropdown перед секцией Character
Tab:CreateDropdown({
   Name = "Teleport to Zone",
   Options = zoneNames,
   CurrentOption = "",
   MultipleOptions = false,
   Flag = "ZoneDropdown", 
   Callback = function(Option)
      local targetZone = zonesFolder:FindFirstChild(Option[1]) -- Rayfield возвращает таблицу для Single Dropdown
      if targetZone then
          local char = game.Players.LocalPlayer.Character
          local hrp = char and char:FindFirstChild("HumanoidRootPart")
          
          if hrp then
              -- Телепортируем к позиции объекта (CFrame)
              if targetZone:IsA("Model") then
                  hrp.CFrame = targetZone:GetPivot()
              else
                  hrp.CFrame = targetZone.CFrame + Vector3.new(0, 3, 0) -- Чуть выше, чтобы не застрять
              end
          end
      end
   end,
})

-- 6. Section "• Character •"
Tab:CreateSection("• Character •")

-- 7. Slider "Walkspeed"
local WalkSpeedValue = 16
Tab:CreateSlider({
   Name = "Walkspeed",
   Range = {16, 300},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Callback = function(Value)
      WalkSpeedValue = Value
   end,
})

-- Цикл для установки скорости каждый кадр
game:GetService("RunService").RenderStepped:Connect(function()
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = WalkSpeedValue
    end
end)

-- 8. Toggle "Noclip"
local NoclipEnabled = false
Tab:CreateToggle({
   Name = "Noclip",
   CurrentValue = false,
   Callback = function(Value)
      NoclipEnabled = Value
   end,
})

-- Логика Noclip
game:GetService("RunService").Stepped:Connect(function()
    if NoclipEnabled then
        local char = game.Players.LocalPlayer.Character
        if char then
            if char:FindFirstChild("Head") then char.Head.CanCollide = false end
            if char:FindFirstChild("UpperTorso") then char.UpperTorso.CanCollide = false end
            if char:FindFirstChild("LowerTorso") then char.LowerTorso.CanCollide = false end
            if char:FindFirstChild("Torso") then char.Torso.CanCollide = false end -- Для R6
        end
    end
end)
