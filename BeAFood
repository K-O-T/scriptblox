-- 5: Freeze NPCs с проверкой дистанции (10 studs)
MainTab:CreateToggle({
   Name = "Freeze NPCs",
   CurrentValue = false,
   Callback = function(Value)
      flags.freezeNpcs = Value
      task.spawn(function()
         local pathStart = workspace:WaitForChild("World"):WaitForChild("Shared"):WaitForChild("Zones"):WaitForChild("PathStart"):FindFirstChild("Part")
         
         while flags.freezeNpcs do
            local npcFolder = workspace:FindFirstChild("_ClientNPCs")
            
            if npcFolder and pathStart then
               local npcs = npcFolder:GetChildren()
               local farthestNpc = nil
               local maxDistance = -1

               -- 1. Находим самого дальнего NPC
               for _, npc in ipairs(npcs) do
                  if npc:IsA("Model") then
                     local root = npc.PrimaryPart or npc:FindFirstChild("HumanoidRootPart")
                     if root then
                        local dist = (root.Position - pathStart.Position).Magnitude
                        if dist > maxDistance then
                           maxDistance = dist
                           farthestNpc = npc
                        end
                     end
                  end
               end

               -- 2. Применяем заморозку/разморозку
               for _, npc in ipairs(npcs) do
                  if npc:IsA("Model") then
                     local root = npc.PrimaryPart or npc:FindFirstChild("HumanoidRootPart")
                     if root then
                        if npc == farthestNpc then
                           root.Anchored = false -- Самый дальний двигается
                        else
                           root.Anchored = true  -- Остальные стоят
                        end
                     end
                  end
               end
            end
            task.wait(0.2) -- Частота обновления проверки
         end

         -- Разморозка всех при выключении Toggle
         local npcFolder = workspace:FindFirstChild("_ClientNPCs")
         if npcFolder then
            for _, npc in ipairs(npcFolder:GetChildren()) do
               local root = npc.PrimaryPart or npc:FindFirstChild("HumanoidRootPart")
               if root then root.Anchored = false end
            end
         end
      end)
   end,
})

-- 6: Auto Run + Удержание "W" (Force Press)
MainTab:CreateToggle({
   Name = "Auto Run",
   CurrentValue = false,
   Callback = function(Value)
      flags.autoRun = Value
      if Value then
         -- Цикл удержания клавиши (даже при потере фокуса окна)
         task.spawn(function()
            while flags.autoRun do
               VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
               task.wait(0.1)
            end
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)
         end)
         
         -- Телепортация
         task.spawn(function()
            while flags.autoRun do
               local target = workspace:WaitForChild("World"):WaitForChild("Shared"):WaitForChild("Zones"):WaitForChild("PathStart"):FindFirstChild("Part")
               local hrp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
               if target and hrp then
                  hrp.CFrame = target.CFrame
               end
               task.wait(.75)
            end
         end)
      end
   end,
})

