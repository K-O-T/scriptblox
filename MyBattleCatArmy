local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "[ My Battle Cat Army ]",
   LoadingTitle = "By K7240",
   LoadingSubtitle = "Loading...",
   ConfigurationSaving = {
      Enabled = false,
      FolderName = "BattleCatConfig",
      FileName = "MainHub"
   }
})

local cashAmount = 100

local Tab = Window:CreateTab("Enjoy!", "heart") 

Tab:CreateInput({
   Name = "Amount Of Cash",
   PlaceholderText = "100",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local num = tonumber(Text)
      if num then
         cashAmount = num
      else
         cashAmount = 100
      end
   end,
})

Tab:CreateButton({
   Name = "Get Cash",
   Callback = function()
      local args = {
          "GetCoin",
          cashAmount
      }
      local remote = game:GetService("ReplicatedStorage"):WaitForChild("Remote", 5):WaitForChild("Battle", 5)
      if remote then
          remote:FireServer(unpack(args))
      else
          Rayfield:Notify({Title = "Error", Content = "Remote not found!", Duration = 3})
      end
   end,
})

Tab:CreateParagraph({Title = "Info.", Content = "To Get Cash You Need Atleast 1 Cat Placed."})
Tab:CreateParagraph({Title = "Warn!", Content = "Inf Cash May Cause Endless Loading! It's Probably Can't Be Fixed."})

local HelpSection = Tab:CreateSection("Helpful")

Tab:CreateButton({
   Name = "Delete Loading Screen",
   Callback = function()
      local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
      local loadingGui = playerGui:FindFirstChild("LoadingGui")
      
      if loadingGui then
         loadingGui:Destroy()
      else
         Rayfield:Notify({
            Title = "Status",
            Content = "LoadingGui not found or already deleted.",
            Duration = 3
         })
      end
   end,
})

